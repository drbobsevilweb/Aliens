{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aliens://schemas/mission-package-v1",
  "title": "Aliens Mission Package V1",
  "type": "object",
  "required": ["version", "maps", "missions"],
  "properties": {
    "version": { "const": "1.0" },
    "maps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "width", "height", "terrain", "doors", "markers"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "width": { "type": "integer", "minimum": 8, "maximum": 256 },
          "height": { "type": "integer", "minimum": 8, "maximum": 256 },
          "terrain": { "type": "array" },
          "doors": { "type": "array" },
          "markers": { "type": "array" },
          "floorTextureKey": { "type": "string" },
          "wallTextureKey": { "type": "string" },
          "terrainTextures": { "type": "array" },
          "props": { "type": "array" },
          "lights": { "type": "array" },
          "storyPoints": { "type": "array" },
          "spawnPoints": { "type": "array" },
          "atmosphere": { "type": "object" },
          "largeTextures": { "type": "array" }
        },
        "additionalProperties": false
      }
    },
    "missions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "mapId", "difficulty"],
        "properties": {
          "id": { "type": "string", "pattern": "^m[0-9]+$" },
          "name": { "type": "string" },
          "mapId": { "type": "string" },
          "difficulty": { "type": "string", "enum": ["normal", "hard", "extreme"] },
          "enemyBudget": { "type": "integer", "minimum": 0, "maximum": 999 },
          "requiredCards": { "type": "integer", "minimum": 0, "maximum": 8 },
          "requiredTerminals": { "type": "integer", "minimum": 0, "maximum": 8 },
          "objective": { "type": "string" },
          "notes": { "type": "string" },
          "director": {
            "type": "object",
            "properties": {
              "idlePressureBaseMs": { "type": "number", "minimum": 500, "maximum": 60000 },
              "idlePressureMinMs": { "type": "number", "minimum": 500, "maximum": 60000 },
              "gunfireReinforceBaseMs": { "type": "number", "minimum": 500, "maximum": 60000 },
              "gunfireReinforceMinMs": { "type": "number", "minimum": 500, "maximum": 60000 },
              "reinforceCap": { "type": "integer", "minimum": 0, "maximum": 200 },
              "reinforceCapIdle": { "type": "integer", "minimum": 0, "maximum": 200 },
              "reinforceCapGunfire": { "type": "integer", "minimum": 0, "maximum": 200 },
              "doorNoiseMemoryMs": { "type": "number", "minimum": 500, "maximum": 120000 },
              "idleSpawnMemoryMs": { "type": "number", "minimum": 500, "maximum": 120000 },
              "waveTransitionGraceMs": { "type": "number", "minimum": 0, "maximum": 60000 },
              "inactivityAmbushMs": { "type": "number", "minimum": 1000, "maximum": 120000 },
              "inactivityAmbushCooldownMs": { "type": "number", "minimum": 500, "maximum": 120000 }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "directorEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "trigger", "action"],
        "properties": {
          "id": { "type": "string" },
          "trigger": {
            "type": "string",
            "pattern": "^(always|time:[0-9]+(\\.[0-9]+)?|wave:[0-9]+|pressure:(0(\\.[0-9]+)?|1(\\.0+)?)|kills:[0-9]+|objective:[0-9]+|stage:(combat|intermission|extract|victory|defeat))$"
          },
          "action": {
            "type": "string",
            "enum": [
              "spawn_pack",
              "text_cue",
              "cue_text",
              "show_text",
              "door_thump",
              "thump",
              "edge_cue",
              "set_pressure_grace",
              "door_action",
              "door_state",
              "set_reinforce_caps",
              "set_reinforcement_caps",
              "set_lighting",
              "set_combat_mods",
              "morale_delta",
              "panic_delta",
              "trigger_tracker",
              "start_tracker",
              "spawn_queen",
              "spawn_boss"
            ]
          },
          "params": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "audioCues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "textCue"],
        "properties": {
          "id": { "type": "string" },
          "textCue": { "type": "string" },
          "priority": { "type": "integer", "minimum": 0, "maximum": 10 }
        },
        "additionalProperties": true
      }
    },
    "nodeGraphs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "nodes", "connections"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "data"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "type": { "type": "string" },
                "x": { "type": "number" },
                "y": { "type": "number" },
                "data": { "type": "object" }
              },
              "additionalProperties": true
            }
          },
          "connections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["fromNode", "toNode"],
              "properties": {
                "id": { "type": "string" },
                "fromNode": { "type": "string", "minLength": 1 },
                "toNode": { "type": "string", "minLength": 1 },
                "fromPort": { "type": "string" },
                "toPort": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "gameConfig": {
      "type": "object"
    },
    "hudConfig": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
